{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swarm-flow.dev/schemas/policy.schema.json",
  "title": "swarm-flow Policy",
  "type": "object",
  "required": ["id"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "phase_entry_requires_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "approval_required_phases": { "type": "array", "items": { "type": "string" } },
    "phase_completion_requires_registered_artifacts": { "type": "boolean" },
    "external_writes_require_preview": { "type": "boolean" },
    "allowed_external_write_connectors": { "type": "array", "items": { "type": "string" } },
    "block_delivery_when_validation_failed": { "type": "boolean" },
    "risk_score_approval_threshold": { "type": "number" },
    "delivery_readiness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires_validation_status": { "type": "string" },
        "requires_review_report": { "type": "boolean" },
        "requires_qa_report": { "type": "boolean" },
        "requires_release_notes": { "type": "boolean" },
        "requires_risk_approval_when_threshold_exceeded": { "type": "boolean" }
      }
    },
    "blocked_without_approval": { "type": "array", "items": { "type": "string" } },
    "manageable_pr_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_changed_files_warn": { "type": "number" },
        "max_changed_files_block": { "type": "number" },
        "max_changed_lines_warn": { "type": "number" },
        "max_changed_lines_block": { "type": "number" },
        "max_packages_warn": { "type": "number" },
        "max_packages_block": { "type": "number" },
        "block_mixed_migration_and_behavior_change": { "type": "boolean" },
        "block_unrelated_concerns": { "type": "boolean" },
        "require_slice_plan_before_implementation": { "type": "boolean" },
        "allow_override_with_approval": { "type": "boolean" }
      }
    },
    "external_comment_posting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_mode", "require_user_selection", "allow_auto_post"],
      "properties": {
        "default_mode": { "const": "preview" },
        "require_user_selection": { "type": "boolean" },
        "allow_auto_post": { "type": "boolean" }
      }
    }
  }
}
